# =============================================================
# Travel&Go — Variables de Entorno
# Copia este archivo como apps/api/.env y completa los valores
# =============================================================

# App
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# -------------------------------------------------------------
# RapidAPI (un solo key para vuelos y hoteles)
# Crea cuenta en: https://rapidapi.com (email personal)
# Suscríbete GRATIS a:
#   - Sky Scrapper: rapidapi.com/apiheya/api/sky-scrapper
#   - Makcorps Hotel API: rapidapi.com/makcorps/api/makcorps-hotel-api
# Tu API key aparece en cualquiera de esas páginas en "Header Parameters"
# -------------------------------------------------------------
RAPIDAPI_KEY=

# -------------------------------------------------------------
# OpenWeatherMap (clima)
# Regístrate gratis en: https://openweathermap.org/api
# Tier gratuito: 1,000,000 llamadas/mes
# -------------------------------------------------------------
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# -------------------------------------------------------------
# Open Exchange Rates (moneda)
# Regístrate gratis en: https://openexchangerates.org
# Tier gratuito: 1,000 llamadas/mes (base USD)
# -------------------------------------------------------------
OPEN_EXCHANGE_RATES_APP_ID=
OPEN_EXCHANGE_RATES_BASE_URL=https://openexchangerates.org/api

# -------------------------------------------------------------
# TimezoneDB (zona horaria)
# Regístrate gratis en: https://timezonedb.com/register
# Tier gratuito: 1 llamada/segundo
# -------------------------------------------------------------
TIMEZONEDB_API_KEY=
TIMEZONEDB_BASE_URL=http://api.timezonedb.com/v2.1

# -------------------------------------------------------------
# Unsplash (fotos de destinos)
# Regístrate gratis en: https://unsplash.com/developers
# Tier gratuito: 50 llamadas/hora en demo
# -------------------------------------------------------------
UNSPLASH_ACCESS_KEY=
UNSPLASH_BASE_URL=https://api.unsplash.com
